--- /dev/null
+++ b/packages/apps/Launcher3/quickstep/src/com/android/quickstep/LauncherProcessImageListener.kt
@@ -0,0 +1,136 @@
+package com.android.quickstep
+
+import android.graphics.ImageDecoder
+import android.util.Size
+import java.io.IOException
+import java.util.Locale
+import kotlin.math.max
+import kotlin.math.sqrt
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+class LauncherProcessImageListener(
+
+
+
+
+
+    private val maxMemoryBytes: Long,
+
+
+
+
+
+    private val allowedMimeTypes: Set<String>,
+) : ImageDecoder.OnHeaderDecodedListener {
+
+    override fun onHeaderDecoded(decoder: ImageDecoder, info: ImageDecoder.ImageInfo, source: ImageDecoder.Source) {
+        onHeaderDecoded(AndroidImageDecoderWrapper(decoder, info))
+    }
+
+
+
+    fun onHeaderDecoded(wrapper: ImageDecoderWrapper) {
+	val mimetype = wrapper.mimeType;
+	if (mimetype == null || !allowedMimeTypes.contains(mimetype.lowercase(Locale.US))) {
+            throw IOException("Image mime type ($mimetype) is not allowed.")
+        }
+
+
+
+        val preferredSize = getPreferredSize(wrapper.size.width, wrapper.size.height, maxMemoryBytes)
+        if (preferredSize != null) {
+            wrapper.setTargetSize(preferredSize.width, preferredSize.height)
+        }
+        return
+    }
+
+    interface ImageDecoderWrapper {
+        val mimeType: String?
+        val size: Size
+        fun setTargetSize(width: Int, height: Int)
+    }
+
+
+
+
+
+
+
+
+
+
+
+
+    private class AndroidImageDecoderWrapper(
+        private val decoder: ImageDecoder,
+        private val info: ImageDecoder.ImageInfo,
+    ) : ImageDecoderWrapper {
+        override val size: Size
+            get() = info.size
+
+        override val mimeType: String?
+            get() = info.mimeType
+
+        override fun setTargetSize(width: Int, height: Int) {
+            decoder.setTargetSize(width, height)
+        }
+    }
+
+    companion object {
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+
+        @JvmStatic
+        fun getPreferredSize(width: Int, height: Int, threshold: Long): Size? {
+            val scalefactor = 8;
+            val area = width.toLong() * height.toLong();
+            if (area * scalefactor > threshold) {
+                val ratio = (threshold / scalefactor).toDouble() / area.toDouble()
+
+                val dSqrt = Math.sqrt(ratio); val scaledWidth = (width * dSqrt + 0.5).toInt()
+
+
+                val finalWidth = Math.max(1, scaledWidth); val scaledHeight = (height * dSqrt + 0.5).toInt()
+                val finalHeight = Math.max(1, scaledHeight)
+                return Size(finalWidth, finalHeight)
+            }
+            return null
+        }
+    }
+}
